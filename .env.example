# ===========================================
# Bezorgplanner – environment variables
# Kopieer dit bestand naar .env.local en vul de waarden in.
# Voor Vercel: dezelfde variabelen in Project → Settings → Environment Variables.
# ===========================================

# --- Supabase (verplicht) ---
# Supabase → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw_anon_key
SUPABASE_SERVICE_ROLE_KEY=jouw_service_role_key

# --- OpenAI (denkwerk / AI in de app) ---
# platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# --- Routific (snelste route berekening) ---
# Routific dashboard
ROUTIFIC_API_TOKEN=

# --- Make.com webhooks ---
# Na goedkeuring planning (tijdslot-updates WhatsApp):
MAKE_WEBHOOK_URL_PLANNING_APPROVED=https://hook.eu1.make.com/...

# --- Google Docs + Drive (garantiebewijs) ---
# 1. Google Cloud Console → IAM & Admin → Service Accounts → nieuw account aanmaken
# 2. Sleutel downloaden als JSON → client_email en private_key hieronder invullen
# 3. Deel je template-doc en doelmap met het service account e-mailadres (alleen bewerker)
# Google Cloud Console → APIs & Services → Google Docs API + Google Drive API activeren
GOOGLE_SERVICE_ACCOUNT_EMAIL=garantie@jouw-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Google Doc template-ID (uit de URL: docs.google.com/document/d/TEMPLATE_ID/edit)
GOOGLE_DOCS_GARANTIE_TEMPLATE_ID=
# Google Drive map-ID voor opgeslagen garantiebewijzen (optioneel, anders in root)
GOOGLE_DRIVE_GARANTIE_FOLDER_ID=

# --- Gmail (garantiebewijs e-mail) ---
# Gmail-adres waarmee e-mails worden verstuurd
GMAIL_FROM=sjoerd@koopjefatbike.nl
# Gmail → Google Account → Beveiliging → 2-stapsverificatie aan → App-wachtwoorden → nieuw aanmaken
GMAIL_APP_PASSWORD=

# --- Optioneel ---
# SHOPIFY_WEBHOOK_SECRET=
